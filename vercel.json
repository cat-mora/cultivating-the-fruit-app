{
  "buildCommand": "cd app && npm install && npx expo export -p web",
  "outputDirectory": "app/dist",
  "installCommand": "cd app && npm install",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "EXPO_PUBLIC_SUPABASE_URL": "@expo_public_supabase_url",
      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "@expo_public_supabase_anon_key",
      "EXPO_PUBLIC_ENABLE_SUPABASE": "@expo_public_enable_supabase",
      "EXPO_PUBLIC_ENABLE_WEB_PLATFORM": "@expo_public_enable_web_platform",
      "EXPO_PUBLIC_ENABLE_PARTNER_SHARING": "@expo_public_enable_partner_sharing"
    }
  }
}
