{
  "buildCommand": "npx expo export -p web && cp -R public/. dist/",
  "outputDirectory": "dist",
  "devCommand": "npx expo start --web",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "env": {
    "EXPO_PUBLIC_SUPABASE_URL": "https://onwijddzljigbizsnrpo.supabase.co",
    "EXPO_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9ud2lqZGR6bGppZ2JpenNucnBvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY1NDA3MTEsImV4cCI6MjA5MjExNjcxMX0.UrJBGCrlWp3ADORy6BnYJuWovConIyU_MUzHHdiIEUU",
    "EXPO_PUBLIC_WEB_URL": "https://app.cultivatingthefruit.com",
    "EXPO_PUBLIC_ENABLE_SUPABASE": "true",
    "EXPO_PUBLIC_ENABLE_WEB_PLATFORM": "true",
    "EXPO_PUBLIC_ENABLE_PARTNER_SHARING": "true"
  }
}
